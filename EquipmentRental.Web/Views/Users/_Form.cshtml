@model RegisterInput
<form method="post">
    <div class="mb-3"><label asp-for="Username"></label><input asp-for="Username" class="form-control" /></div>
    <div class="mb-3"><label asp-for="FirstName"></label><input asp-for="FirstName" class="form-control" /></div>
    <div class="mb-3"><label asp-for="LastName"></label><input asp-for="LastName" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Password"></label><input asp-for="Password" type="password" class="form-control" /></div>
    <button class="btn btn-primary" type="submit">Запази</button>
    <div asp-validation-summary="ModelOnly" class="text-danger mt-2"></div>
</form>
