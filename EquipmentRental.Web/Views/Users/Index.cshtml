@model List<User>
@{
    ViewData["Title"] = "Потребители";
}
<h2>Потребители</h2>
<a class="btn btn-primary mb-3" asp-action="Create">Добави потребител</a>
<table class="table table-bordered">
    <thead><tr><th>Потребителско име</th><th>Име</th><th>Роля</th><th>Действия</th></tr></thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td><td>@user.FirstName @user.LastName</td><td>@user.Role?.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Редакция</a>
                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline"><button class="btn btn-sm btn-danger">Изтрий</button></form>
                </td>
            </tr>
        }
    </tbody>
</table>
