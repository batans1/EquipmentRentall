@using EquipmentRental.Data
@using EquipmentRental.Web.Extensions
@model List<EquipmentItem>
@{
    ViewData["Title"] = "Оборудване";
}
<h2>Оборудване</h2>
<div class="section-head">
    <p class="muted mb-0">Преглед и търсене на наличните артикули.</p>
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary" asp-action="Create">Добави оборудване</a>
    }
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-5"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Търси по име" /></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100" type="submit">Търси</button></div>
</form>
<div class="table-wrap">
<table class="table table-bordered mb-0">
    <thead><tr><th>Снимка</th><th>Име</th><th>Описание</th><th>Количество</th><th>Състояние</th><th>Действия</th></tr></thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td><img src="@item.ImageUrl" alt="@item.Name" class="eq-thumb" /></td>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.AvailableQuantity</td>
                    <td>@item.Condition.GetDisplayName()</td>
                <td>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редакция</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"><button class="btn btn-sm btn-danger">Изтрий</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
