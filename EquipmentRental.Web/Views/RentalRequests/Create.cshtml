@model RentalCreateInput
@{
    ViewData["Title"] = "Нова заявка";
    var equipment = ViewBag.Equipment as List<EquipmentItem> ?? new List<EquipmentItem>();
}
<h2>Нова заявка</h2>
<p class="muted">Избери период, цел и количества за нужните артикули.</p>
<form method="post">
    <div class="row">
        <div class="col-md-4 mb-3"><label asp-for="StartDate"></label><input asp-for="StartDate" type="date" class="form-control" /></div>
        <div class="col-md-4 mb-3"><label asp-for="EndDate"></label><input asp-for="EndDate" type="date" class="form-control" /></div>
    </div>
    <div class="mb-3"><label asp-for="Purpose"></label><input asp-for="Purpose" class="form-control" /></div>
    <h5 class="mt-2">Избери артикули</h5>
    <div class="table-wrap mb-3">
        <table class="table mb-0">
            <thead><tr><th>Снимка</th><th>Артикул</th><th>Наличност</th><th>Количество</th></tr></thead>
            <tbody>
                @foreach (var item in equipment)
                {
                    <tr>
                        <td><img src="@item.ImageUrl" alt="@item.Name" class="eq-thumb" /></td>
                        <td>@item.Name</td>
                        <td>@item.AvailableQuantity</td>
                        <td><input type="number" min="0" max="@item.AvailableQuantity" name="Quantities[@item.Id]" value="0" class="form-control" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <button class="btn btn-primary" type="submit">Изпрати заявка</button>
    <div asp-validation-summary="ModelOnly" class="text-danger mt-2"></div>
</form>
